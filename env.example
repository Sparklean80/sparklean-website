# Sparklean quote intake — Netlify environment variables
# Site settings → Environment variables (set for Production and Deploy previews as needed).

# --- Outbound email only (Resend → your inbox) ---
# No inbound MX on Resend is required. Google Workspace / Gmail can still receive at SPARKLEAN_LEAD_TO.

# Required: Resend API key (starts with re_…)
RESEND_API_KEY=

# Required: From address on a domain you verified in Resend (DNS).
# Examples: "Sparklean Quotes <quotes@sparklean.co>" or "Sparklean <noreply@sparklean.co>"
# Do not use Gmail, personal mail, or an unverified domain as the sender.
SPARKLEAN_FROM_EMAIL=

# Required: Where lead emails are delivered (inbox can be Gmail / Google Workspace).
SPARKLEAN_LEAD_TO=info@sparklean.co

# Optional: OpenAI for a short internal summary only. If missing or errors, the lead email still sends.
OPENAI_API_KEY=

# After a failed send: Netlify → Functions → quote-submit → Logs. Look for lines starting with [quote-submit].
