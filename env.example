# Sparklean quote intake — Netlify environment variables
# Site settings → Environment variables (Production / Deploy previews).

# Required: Brevo transactional API key (SMTP API).
BREVO_API_KEY=

# Sender (must be allowed in Brevo; DKIM on your domain).
SPARKLEAN_FROM_EMAIL=info@sparklean.co

# Inbox where lead emails are delivered.
SPARKLEAN_LEAD_TO=info@sparklean.co

# Optional: OpenAI for a short internal summary only. If missing or errors, the lead email still sends.
OPENAI_API_KEY=

# Optional: Slack incoming webhook — short internal ping after a successful Brevo send (no secrets in the message body).
SPARKLEAN_SLACK_WEBHOOK_URL=

# Future: 6PM digest (visitors, funnel, attribution) — requires a separate analytics store + scheduled job; not emitted by quote-submit yet.
