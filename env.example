# Sparklean quote intake — Netlify environment variables
# Copy to Netlify UI (Site settings → Environment variables) or use a local .env with `netlify dev`.

# Required: OpenAI for a short, controlled lead summary (no pricing).
OPENAI_API_KEY=

# Required: Resend (https://resend.com) for outbound email.
RESEND_API_KEY=

# Verified sender on your Resend domain (e.g. leads@updates.sparklean.co).
# Must use an address on a domain you have verified in Resend — not a random Gmail.
SPARKLEAN_FROM_EMAIL=

# Recipient for new leads (default if unset: info@sparklean.co).
SPARKLEAN_LEAD_TO=info@sparklean.co

# Optional: set to 1 to return Resend's error message in the JSON `hint` field (helps debug; turn off after go-live).
SPARKLEAN_QUOTE_VERBOSE_ERRORS=0

# --- If submit shows "Unable to deliver email" ---
# 1. Resend → Domains: verify the domain used in SPARKLEAN_FROM_EMAIL (SPF/DKIM).
# 2. SPARKLEAN_FROM_EMAIL must be that domain (e.g. leads@updates.sparklean.co), not info@ until that domain is verified in Resend.
# 3. RESEND_API_KEY must be the full "re_..." key from Resend (Netlify production env, not only local).
# 4. Netlify → Functions → quote-submit → logs: open after a failed submit to see Resend status + body.
# 5. Deploy latest code: function retries once without the JSON attachment if the first send fails.
