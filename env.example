# Sparklean quote intake — Netlify environment variables
# Copy to Netlify UI (Site settings → Environment variables) or use a local .env with `netlify dev`.

# Required: OpenAI for a short, controlled lead summary (no pricing).
OPENAI_API_KEY=

# Required: Resend (https://resend.com) for outbound email.
RESEND_API_KEY=

# Verified sender on your Resend domain (e.g. leads@mail.sparklean.co).
SPARKLEAN_FROM_EMAIL=

# Recipient for new leads (default if unset: info@sparklean.co).
SPARKLEAN_LEAD_TO=info@sparklean.co
